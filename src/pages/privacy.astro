---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { site } from '../config/site';
// Starting-point PDPA privacy policy — owner should review before relying on it.
const updated = '12 กรกฎาคม 2569';
---
<BaseLayout
  title="นโยบายความเป็นส่วนตัว | หมาสนุก"
  description="นโยบายความเป็นส่วนตัวของ หมาสนุก (dogsanook.com) — การเก็บและใช้ข้อมูลส่วนบุคคลตาม พ.ร.บ. คุ้มครองข้อมูลส่วนบุคคล (PDPA)"
  path="/privacy"
>
  <Nav />
  <main class="legal">
    <h1>นโยบายความเป็นส่วนตัว</h1>
    <p class="updated">ปรับปรุงล่าสุด: {updated}</p>

    <p class="lead">{site.name} (dogsanook.com) ให้ความสำคัญกับความเป็นส่วนตัวของคุณ นโยบายนี้อธิบายว่าเราเก็บ ใช้ และดูแลข้อมูลส่วนบุคคลของคุณอย่างไร ตามพระราชบัญญัติคุ้มครองข้อมูลส่วนบุคคล พ.ศ. 2562 (PDPA)</p>

    <h2>1. ข้อมูลที่เราเก็บ</h2>
    <ul>
      <li>ข้อมูลติดต่อ: ชื่อ, LINE ID, เบอร์โทรศัพท์</li>
      <li>ข้อมูลเกี่ยวกับสุนัขและการฝึก: พันธุ์ อายุ พฤติกรรม และปัญหาที่ต้องการแก้</li>
      <li>ที่อยู่ / พื้นที่ให้บริการ เฉพาะเพื่อการไปสอนถึงบ้าน</li>
      <li>ภาพถ่าย / คลิปวิดีโอระหว่างการฝึก — เฉพาะเมื่อคุณให้ความยินยอมเท่านั้น</li>
    </ul>
    <p>เรา<strong>ไม่เก็บข้อมูลการชำระเงินออนไลน์</strong> เพราะเว็บไซต์ไม่มีระบบชำระเงิน</p>

    <h2>2. เราใช้ข้อมูลเพื่ออะไร</h2>
    <ul>
      <li>ติดต่อกลับ ตอบคำถาม นัดหมาย และให้บริการฝึกสุนัข</li>
      <li>วางแผนการฝึกให้เหมาะกับน้องแต่ละตัว</li>
      <li>ปรับปรุงคุณภาพบริการ</li>
      <li>ใช้ภาพ / คลิปเพื่อประชาสัมพันธ์บนเว็บและโซเชียล <strong>เฉพาะกรณีที่คุณยินยอม</strong> (เช่น โปรลูกค้าชุดแรกที่แลกกับการอนุญาตถ่ายคลิป)</li>
    </ul>

    <h2>3. ฐานในการประมวลผลข้อมูล</h2>
    <p>เราประมวลผลข้อมูลบนฐานความยินยอมของคุณ และ/หรือเพื่อการให้บริการตามที่คุณร้องขอ</p>

    <h2>4. การเปิดเผยข้อมูล</h2>
    <p>เรา<strong>ไม่ขายหรือให้เช่า</strong>ข้อมูลของคุณ และจะไม่เปิดเผยต่อบุคคลภายนอก เว้นแต่เท่าที่จำเป็นต่อการให้บริการหรือที่กฎหมายกำหนด</p>

    <h2>5. คุกกี้และบริการภายนอก</h2>
    <ul>
      <li>เว็บไซต์นี้ไม่ใช้คุกกี้ติดตามเพื่อการโฆษณา</li>
      <li>เมื่อมีการฝังคลิปวิดีโอจากผู้ให้บริการภายนอก (เช่น YouTube) ผู้ให้บริการนั้นอาจตั้งคุกกี้ตามนโยบายของตนเอง</li>
      <li>การติดต่อผ่าน LINE อยู่ภายใต้นโยบายความเป็นส่วนตัวของ LINE ด้วย</li>
    </ul>

    <h2>6. ระยะเวลาเก็บข้อมูล</h2>
    <p>เราเก็บข้อมูลเท่าที่จำเป็นต่อการให้บริการและตามที่กฎหมายกำหนด เมื่อไม่จำเป็นแล้วจะลบหรือทำให้ไม่สามารถระบุตัวตนได้</p>

    <h2>7. สิทธิของคุณตาม PDPA</h2>
    <p>คุณมีสิทธิขอเข้าถึง แก้ไข ลบ คัดค้าน ขอให้ระงับการใช้ หรือถอนความยินยอมในการใช้ข้อมูลของคุณ โดยติดต่อเราได้ตามช่องทางด้านล่าง</p>

    <h2>8. ติดต่อเรื่องข้อมูลส่วนบุคคล</h2>
    <ul>
      <li>LINE: <a href={site.lineUrl} target="_blank" rel="noopener">{site.lineOaId}</a></li>
      <li>โทร: <a href={`tel:${site.phoneTel}`}>{site.phone}</a></li>
    </ul>

    <p style="margin-top:32px;"><a href="/">← กลับหน้าหลัก</a></p>
  </main>
  <Footer />
</BaseLayout>
