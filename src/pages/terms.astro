---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { site } from '../config/site';
// Starting-point service terms — owner should review before relying on it.
const updated = '12 กรกฎาคม 2569';
const zones = site.zones.join(' · ');
---
<BaseLayout
  title="ข้อกำหนดและเงื่อนไข | หมาสนุก"
  description="ข้อกำหนดและเงื่อนไขการให้บริการฝึกสุนัขถึงบ้านของ หมาสนุก (dogsanook.com)"
  path="/terms"
>
  <Nav />
  <main class="legal">
    <h1>ข้อกำหนดและเงื่อนไขการให้บริการ</h1>
    <p class="updated">ปรับปรุงล่าสุด: {updated}</p>

    <p class="lead">ยินดีต้อนรับสู่ {site.name} (dogsanook.com) การติดต่อใช้บริการของเราถือว่าคุณได้อ่านและยอมรับข้อกำหนดต่อไปนี้</p>

    <h2>1. บริการของเรา</h2>
    <p>{site.name} ให้บริการ <strong>ฝึกสุนัขถึงบ้าน</strong> ในกรุงเทพฯ (โซน{zones} และพื้นที่ใกล้เคียง) ด้วยแนวทางเล่นไปฝึกไป เน้นเสริมแรงบวก ไม่ดุ ไม่บังคับ</p>

    <h2>2. ขอบเขตการรับงาน</h2>
    <ul>
      <li><strong>รับ:</strong> ปูพื้นฐานลูกสุนัข · มารยาทในบ้าน · recall และเกม · ทริก</li>
      <li><strong>ยังไม่รับ:</strong> เคสก้าวร้าว กัดคน/กัดสุนัข หรือความกลัว/ระแวงขั้นรุนแรง — กรณีเหล่านี้ขอปรึกษาเป็นเคส ๆ ก่อน</li>
    </ul>

    <h2>3. การนัดหมายและชำระเงิน</h2>
    <ul>
      <li>นัดหมายผ่าน LINE หรือโทรศัพท์</li>
      <li>ชำระเงินโดยการโอน / ติดต่อโดยตรง — ไม่มีระบบชำระเงินออนไลน์บนเว็บไซต์</li>
      <li>ราคาปกติ 3,000 บาท/ครั้ง ราคาและโปรโมชั่นเป็นไปตามที่แสดงบนเว็บ ณ เวลานั้น และอาจเปลี่ยนแปลงได้</li>
    </ul>

    <h2>4. โปรลูกค้าชุดแรก</h2>
    <p>โปรลูกค้าชุดแรกมีจำนวนจำกัด และมีเงื่อนไขคือแลกกับการรีวิว และการอนุญาตให้ถ่ายภาพ/คลิประหว่างการฝึกเพื่อการประชาสัมพันธ์</p>

    <h2>5. การเลื่อนหรือยกเลิกนัด</h2>
    <p>กรุณาแจ้งล่วงหน้าหากต้องการเลื่อนหรือยกเลิกนัด รายละเอียดเงื่อนไขจะแจ้งให้ทราบทาง LINE ก่อนนัดหมาย</p>

    <h2>6. ผลลัพธ์การฝึก</h2>
    <p>ผลการฝึกสุนัขขึ้นกับหลายปัจจัย โดยเฉพาะความสม่ำเสมอในการฝึกซ้อมของเจ้าของ เราจึง<strong>ไม่รับประกันผลลัพธ์ที่เจาะจงหรือกรอบเวลาที่แน่นอน</strong> แต่มุ่งมั่นให้คำแนะนำและวางแผนอย่างเต็มที่</p>

    <h2>7. ความรับผิดชอบของเจ้าของสุนัข</h2>
    <ul>
      <li>สุนัขควรมีสุขภาพดีและได้รับวัคซีนตามกำหนด</li>
      <li>โปรดแจ้งประวัติพฤติกรรมก้าวร้าว / กัด (ถ้ามี) ตามความจริงก่อนนัด เพื่อความปลอดภัยของทุกฝ่าย</li>
      <li>ดูแลความปลอดภัยของคน สัตว์ และทรัพย์สินระหว่างการฝึกที่บ้าน</li>
    </ul>

    <h2>8. เนื้อหาและทรัพย์สินทางปัญญา</h2>
    <p>เนื้อหา รูปภาพ คลิป และคู่มือบนเว็บไซต์นี้เป็นของ {site.name} สำหรับใช้ส่วนตัวเพื่อการเรียนรู้เท่านั้น ห้ามทำซ้ำหรือเผยแพร่เชิงพาณิชย์โดยไม่ได้รับอนุญาต</p>

    <h2>9. ข้อจำกัดความรับผิด</h2>
    <p>เราให้บริการอย่างสุดความสามารถ แต่ไม่รับผิดต่อความเสียหายทางอ้อมที่เกิดขึ้นนอกเหนือการควบคุมตามสมควร</p>

    <h2>10. การเปลี่ยนแปลงข้อกำหนด</h2>
    <p>เราอาจปรับปรุงข้อกำหนดนี้เป็นครั้งคราว โดยจะแสดงวันที่ปรับปรุงล่าสุดไว้บนหน้านี้</p>

    <h2>11. กฎหมายที่ใช้บังคับ</h2>
    <p>ข้อกำหนดนี้อยู่ภายใต้กฎหมายแห่งราชอาณาจักรไทย</p>

    <h2>ติดต่อเรา</h2>
    <ul>
      <li>LINE: <a href={site.lineUrl} target="_blank" rel="noopener">{site.lineOaId}</a></li>
      <li>โทร: <a href={`tel:${site.phoneTel}`}>{site.phone}</a></li>
    </ul>

    <p style="margin-top:32px;"><a href="/">← กลับหน้าหลัก</a></p>
  </main>
  <Footer />
</BaseLayout>
