---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import ProblemSection from '../components/ProblemSection.astro';
import MethodSection from '../components/MethodSection.astro';
import AboutSection from '../components/AboutSection.astro';
import ServicesCards from '../components/ServicesCards.astro';
import StepsSection from '../components/StepsSection.astro';
import PricingSection from '../components/PricingSection.astro';
import LeadMagnet from '../components/LeadMagnet.astro';
import ProofSection from '../components/ProofSection.astro';
import SocialSection from '../components/SocialSection.astro';
import BlogSection from '../components/BlogSection.astro';
import FAQSection from '../components/FAQSection.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout path="/" includeBusinessSchema={true}>
  <Nav />
  <main>
    <Hero />
    <ProblemSection />
    <MethodSection />
    <AboutSection />
    <ServicesCards />
    <StepsSection />
    <PricingSection />
    <LeadMagnet />
    <ProofSection />
    <SocialSection />
    <BlogSection />
    <FAQSection />
    <FinalCTA />
  </main>
  <Footer />
</BaseLayout>
