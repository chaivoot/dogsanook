---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import ImageSlot from '../../components/ImageSlot.astro';
import { site } from '../../config/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const fmt = (d: Date) =>
  d.toLocaleDateString('th-TH', { year: 'numeric', month: 'long', day: 'numeric' });
// Hero aspect: default landscape 16/9. A non-landscape ratio (e.g. a square
// photo) is capped + centred so it reads as a framed shot, not a giant banner.
const heroRatio = post.data.heroRatio ?? '16/9';
const heroWide = heroRatio === '16/9';

// BlogPosting structured data — helps Google treat each post as an article
// (eligible for date/image in results). publisher/logo match the LocalBusiness.
const postSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  ...(post.data.heroImage
    ? { image: new URL(post.data.heroImage, site.domain).href }
    : {}),
  datePublished: post.data.pubDate.toISOString(),
  dateModified: post.data.pubDate.toISOString(),
  inLanguage: 'th',
  mainEntityOfPage: { '@type': 'WebPage', '@id': `${site.domain}/blog/${post.id}` },
  author: { '@type': 'Person', name: `ครู${site.teacher} — ${site.name}` },
  publisher: {
    '@type': 'Organization',
    name: site.name,
    logo: {
      '@type': 'ImageObject',
      url: `${site.domain}/uploads/logo-gold-mark.png`,
    },
  },
};

// Breadcrumb structured data (หน้าแรก › บทความ › โพสต์) — eligible for the
// breadcrumb trail in Google results instead of a bare URL.
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'หน้าแรก', item: site.domain },
    { '@type': 'ListItem', position: 2, name: 'บทความ', item: `${site.domain}/blog` },
    {
      '@type': 'ListItem',
      position: 3,
      name: post.data.title,
      item: `${site.domain}/blog/${post.id}`,
    },
  ],
};
---
<BaseLayout
  title={`${post.data.title} | หมาสนุก`}
  description={post.data.description}
  path={`/blog/${post.id}`}
  ogImage={post.data.heroImage ?? undefined}
>
  <script type="application/ld+json" set:html={JSON.stringify(postSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Nav />
  <main style="max-width:760px;margin:0 auto;padding:clamp(32px,6vw,64px) clamp(16px,4vw,48px);">
    <a href="/blog" style="display:inline-flex;align-items:center;gap:6px;color:#8A6A18;font-weight:600;font-size:14px;text-decoration:none;margin-bottom:22px;">← กลับไปหน้าบทความ</a>
    <div style="font-size:12.5px;font-weight:700;color:#DFA714;letter-spacing:.05em;margin-bottom:10px;">{post.data.category}</div>
    <h1 style="font-family:'Chonburi',serif;font-weight:400;font-size:clamp(28px,4.6vw,44px);line-height:1.25;margin:0 0 12px;color:#2A2521;">{post.data.title}</h1>
    <div style="font-size:13.5px;color:#b0a595;margin-bottom:26px;">{fmt(post.data.pubDate)}</div>
    {post.data.heroVideo ? (
      <video
        src={post.data.heroVideo}
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        aria-label={post.data.heroAlt ?? post.data.title}
        style="display:block;width:100%;max-width:460px;height:auto;margin:0 auto 30px;border-radius:20px;box-shadow:0 18px 40px -24px rgba(42,37,33,.55);background:#20302F;"
      ></video>
    ) : post.data.heroImage && (
      <div style={`aspect-ratio:${heroRatio};max-width:${heroWide ? '100%' : '460px'};margin:0 auto 30px;border-radius:20px;overflow:hidden;box-shadow:0 18px 40px -24px rgba(42,37,33,.55);`}>
        <ImageSlot src={post.data.heroImage} alt={post.data.heroAlt ?? post.data.title} loading="eager" />
      </div>
    )}
    <article class="prose">
      <Content />
    </article>
    <div style="margin-top:44px;padding:26px 28px;background:#F2E9D8;border-radius:20px;text-align:center;">
      <p style="margin:0 0 16px;font-weight:600;font-size:17px;color:#2A2521;">อยากให้น้องเริ่มเล่นไปฝึกไป?</p>
      <a href={site.lineUrl} target="_blank" rel="noopener" class="btn-gold" style="font-size:16px;padding:13px 26px;" onmouseover="this.style.transform='translateY(2px)';this.style.boxShadow='0 4px 0 #DFA714'" onmouseout="this.style.transform='';this.style.boxShadow='0 6px 0 #DFA714'"><span>💬</span> แอด LINE ปรึกษาฟรี</a>
    </div>
  </main>
  <Footer />
  {post.data.heroVideo && (
    <script is:inline>
      // Respect prefers-reduced-motion: don't autoplay the hero video, give controls instead.
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.querySelectorAll('video[autoplay]').forEach((v) => {
          v.removeAttribute('autoplay');
          v.setAttribute('controls', '');
          v.pause();
        });
      }
    </script>
  )}
</BaseLayout>

<style>
  .prose :global(h2) { font-family: 'Chonburi', serif; font-weight: 400; font-size: 26px; color: #2A2521; margin: 34px 0 12px; line-height: 1.3; }
  .prose :global(h3) { font-weight: 700; font-size: 20px; color: #2A2521; margin: 26px 0 10px; }
  .prose :global(p) { font-size: 17px; line-height: 1.9; color: #4a423a; margin: 0 0 18px; }
  .prose :global(ul), .prose :global(ol) { font-size: 17px; line-height: 1.9; color: #4a423a; padding-left: 24px; margin: 0 0 18px; }
  .prose :global(li) { margin-bottom: 8px; }
  .prose :global(a) { color: #8A6A18; text-decoration: underline; }
  .prose :global(strong) { color: #2A2521; }
  .prose :global(blockquote) { border-left: 4px solid #8A6A18; background: #F2E9D8; margin: 0 0 18px; padding: 14px 22px; border-radius: 0 14px 14px 0; }
</style>
