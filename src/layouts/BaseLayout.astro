---
/*
 * BaseLayout — <head> SEO, fonts, OG/Twitter, JSON-LD. Wraps every page.
 */
import '../styles/tokens.css';
import SeoSchema from '../components/SeoSchema.astro';
import { seo as defaultSeo, site } from '../config/site';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  /** Path only, e.g. "/blog" — resolved against site.domain for canonical/OG. */
  path?: string;
  includeBusinessSchema?: boolean;
  /** Gated/unlisted pages (e.g. the LINE-only guide) — keep out of Google. */
  noindex?: boolean;
}
const {
  title = defaultSeo.title,
  description = defaultSeo.description,
  ogImage = defaultSeo.ogImage,
  path = Astro.url.pathname,
  includeBusinessSchema = false,
  noindex = false,
} = Astro.props;

const canonical = new URL(path, site.domain).href;
const ogImageAbs = new URL(ogImage, site.domain).href;
---
<!doctype html>
<html lang="th">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={defaultSeo.keywords.join(', ')} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />
    <!-- Favicon = main teal brand mark (มอมแมม circle), not the gold-only wordmark -->
    <link rel="icon" type="image/png" href="/uploads/mommam.png" />
    <link rel="apple-touch-icon" href="/uploads/mommam.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:locale" content="th_TH" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />

    <!-- Fonts (CLAUDE.md §4): Chonburi display, Sarabun body -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Chonburi&family=Sarabun:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    {includeBusinessSchema && <SeoSchema />}

    {/* Google Analytics 4 — cookieless (client_storage:'none' → no _ga cookie,
        so the "no cookies" privacy policy stays true, no consent banner needed).
        Runs only on the live domain, not localhost or Vercel preview. */}
    <script define:vars={{ gaId: site.gaId }}>
      if (gaId && location.hostname === 'dogsanook.com') {
        const s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=' + gaId;
        document.head.appendChild(s);
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', gaId, { client_storage: 'none' });
      }
    </script>
  </head>
  <body>
    <slot />

    <!-- Scroll-reveal (respects prefers-reduced-motion; CSS guarantees the
         reduced-motion fallback so content is never hidden without JS). -->
    <script>
      const reduce =
        window.matchMedia &&
        window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduce) {
        const els = Array.from(document.querySelectorAll('[data-reveal]'));
        els.forEach((el) => {
          const e = el as HTMLElement;
          e.style.opacity = '0';
          e.style.transform = 'translateY(28px)';
          e.style.transition = 'opacity .7s ease, transform .7s ease';
        });
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                const e = entry.target as HTMLElement;
                e.style.opacity = '1';
                e.style.transform = 'none';
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12 }
        );
        els.forEach((el) => io.observe(el));
      }
    </script>

    <!-- Lazy YouTube: show a thumbnail, load the privacy-friendly player on
         click. Hydrates any .yt-facade[data-id] (component or Markdown HTML). -->
    <script>
      document
        .querySelectorAll<HTMLElement>('.yt-facade[data-id]')
        .forEach((el) => {
          const id = el.getAttribute('data-id');
          if (!id) return;
          if (!el.style.backgroundImage) {
            el.style.backgroundImage = `url('https://i.ytimg.com/vi/${id}/hqdefault.jpg')`;
          }
          el.setAttribute('role', 'button');
          el.setAttribute('tabindex', '0');
          const load = () => {
            if (el.classList.contains('yt-loaded')) return;
            const iframe = document.createElement('iframe');
            iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
            iframe.title = el.getAttribute('data-title') || 'วิดีโอจากหมาสนุก';
            iframe.allow =
              'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
            iframe.setAttribute('allowfullscreen', '');
            iframe.style.cssText =
              'position:absolute;inset:0;width:100%;height:100%;border:0;';
            el.classList.add('yt-loaded');
            el.appendChild(iframe);
          };
          el.addEventListener('click', load);
          el.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              load();
            }
          });
        });
    </script>
  </body>
</html>
