---
/*
 * JSON-LD @graph: LocalBusiness + WebSite + VideoObject (CLAUDE.md §6).
 * A Service Area Business (no public storefront) serving Bangkok + Samut Prakan
 * zones. All nodes are linked by @id so the entities reference one another.
 * areaServed / sameAs / priceRange kept in sync with src/config/site.ts.
 */
import { site } from '../config/site';

const sameAs = Object.values(site.social);

const business = {
  '@type': 'LocalBusiness',
  '@id': `${site.domain}/#business`,
  name: site.name,
  alternateName: site.nameEn,
  url: site.domain,
  image: `${site.domain}/uploads/logo-gold-mark.png`,
  logo: `${site.domain}/uploads/logo-gold-mark.png`,
  description:
    'ครูฝึกสุนัขถึงบ้าน กรุงเทพฯ สไตล์เล่นไปฝึกไป ไม่ดุ ไม่บังคับ',
  telephone: site.phoneTel,
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: site.phoneTel,
    contactType: 'customer service',
    areaServed: 'TH',
    availableLanguage: ['th'],
  },
  priceRange: '฿฿',
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: site.hoursSpec.days,
    opens: site.hoursSpec.opens,
    closes: site.hoursSpec.closes,
  },
  areaServed: [...site.zones, ...site.zonesNearby].map((z) => ({
    '@type': 'Place',
    name: `${z} ${site.zoneProvince[z] ?? site.city}`,
  })),
  address: {
    '@type': 'PostalAddress',
    addressLocality: site.city,
    addressCountry: 'TH',
  },
  sameAs,
  makesOffer: {
    '@type': 'Offer',
    itemOffered: {
      '@type': 'Service',
      name: 'ฝึกสุนัขถึงบ้าน สไตล์เล่นไปฝึกไป',
      serviceType: 'ครูฝึกสุนัขถึงบ้าน',
      areaServed: site.zones.map((z) => `${z} ${site.zoneProvince[z] ?? site.city}`),
    },
    priceCurrency: 'THB',
    price: String(site.pricing.firstSession.promo),
  },
};

const website = {
  '@type': 'WebSite',
  '@id': `${site.domain}/#website`,
  url: site.domain,
  name: site.name,
  alternateName: site.nameEn,
  inLanguage: 'th',
  publisher: { '@id': `${site.domain}/#business` },
};

const video = {
  '@type': 'VideoObject',
  '@id': `${site.domain}/#hero-video`,
  name: site.heroVideo.name,
  description: site.heroVideo.description,
  thumbnailUrl: [new URL(site.heroVideo.poster, site.domain).href],
  contentUrl: new URL(site.heroVideo.url, site.domain).href,
  uploadDate: site.heroVideo.uploadDate,
  duration: site.heroVideo.duration,
  publisher: { '@id': `${site.domain}/#business` },
  isPartOf: { '@id': `${site.domain}/#website` },
};

const graph = {
  '@context': 'https://schema.org',
  '@graph': [business, website, video],
};
---
<script type="application/ld+json" set:html={JSON.stringify(graph)} />
