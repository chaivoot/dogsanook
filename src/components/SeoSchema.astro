---
/*
 * JSON-LD: LocalBusiness + Service (CLAUDE.md §6).
 * A Service Area Business (no public storefront) serving Bangkok zones.
 * areaServed / sameAs / priceRange kept in sync with src/config/site.ts.
 */
import { site } from '../config/site';

const sameAs = Object.values(site.social);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${site.domain}/#business`,
  name: site.name,
  alternateName: site.nameEn,
  url: site.domain,
  image: `${site.domain}${'/uploads/logo-gold-mark.png'}`,
  logo: `${site.domain}${'/uploads/logo-gold-mark.png'}`,
  description:
    'ครูฝึกสุนัขถึงบ้าน กรุงเทพฯ สไตล์เล่นไปฝึกไป ไม่ดุ ไม่บังคับ',
  telephone: site.phoneTel,
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: site.phoneTel,
    contactType: 'customer service',
    areaServed: 'TH',
    availableLanguage: ['th'],
  },
  priceRange: '฿฿',
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: site.hoursSpec.days,
    opens: site.hoursSpec.opens,
    closes: site.hoursSpec.closes,
  },
  areaServed: [...site.zones, ...site.zonesNearby].map((z) => ({
    '@type': 'Place',
    name: `${z} ${site.city}`,
  })),
  address: {
    '@type': 'PostalAddress',
    addressLocality: site.city,
    addressCountry: 'TH',
  },
  sameAs,
  makesOffer: {
    '@type': 'Offer',
    itemOffered: {
      '@type': 'Service',
      name: 'ฝึกสุนัขถึงบ้าน สไตล์เล่นไปฝึกไป',
      serviceType: 'ครูฝึกสุนัขถึงบ้าน',
      areaServed: site.zones.map((z) => `${z} ${site.city}`),
    },
    priceCurrency: 'THB',
    price: String(site.pricing.firstSession.promo),
  },
};
const videoSchema = {
  '@context': 'https://schema.org',
  '@type': 'VideoObject',
  name: site.heroVideo.name,
  description: site.heroVideo.description,
  thumbnailUrl: [new URL(site.heroVideo.poster, site.domain).href],
  contentUrl: new URL(site.heroVideo.url, site.domain).href,
  uploadDate: site.heroVideo.uploadDate,
  duration: site.heroVideo.duration,
  publisher: { '@id': `${site.domain}/#business` },
};
---
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
<script type="application/ld+json" set:html={JSON.stringify(videoSchema)} />
