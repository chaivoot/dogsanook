---
// "game cards" (CLAUDE.md §5). Keyword phrase from §6 woven into the
// subtitle copy (รับฝึกสุนัขถึงบ้าน กรุงเทพฯ / โซนรามคำแหง–ลาดกระบัง).
// "คอย" appears here as customer-facing search language — primed as
// self-control in the Method section (§9).
---
<section id="services" data-reveal style="background:#F2E9D8;padding:clamp(56px,8vw,110px) clamp(16px,4vw,48px);">
  <div style="max-width:1120px;margin:0 auto;">
    <h2 style="font-family:'Chonburi',serif;font-weight:400;font-size:clamp(28px,5vw,50px);line-height:1.2;margin:0 0 10px;color:#2A2521;text-align:center;">รับฝึกอะไรบ้าง</h2>
    <p style="text-align:center;font-size:16px;color:#6b6157;margin:0 auto 46px;max-width:60ch;">แต่ละทักษะ = เกมหนึ่งใบ เล่นไปฝึกไป — รับฝึกสุนัขถึงบ้าน กรุงเทพฯ โซนรามคำแหง · กรุงเทพกรีฑา · พระราม 9 · ลาดกระบัง</p>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:20px;">
      <div style="position:relative;background:#fff;border-radius:20px;padding:26px 24px;border:1px solid rgba(140,120,80,.16);box-shadow:0 10px 24px -18px rgba(42,37,33,.6);transition:transform .18s,box-shadow .18s;" onmouseover="this.style.transform='translateY(-6px)';this.style.boxShadow='0 20px 36px -20px rgba(42,37,33,.55)'" onmouseout="this.style.transform='';this.style.boxShadow='0 10px 24px -18px rgba(42,37,33,.6)'">
        <div style="position:absolute;top:18px;right:18px;font-size:12px;font-weight:700;color:#DFA714;letter-spacing:.08em;">CARD 01</div>
        <div style="font-size:38px;margin-bottom:14px;">🐶</div>
        <h3 style="font-family:'Chonburi',serif;font-weight:400;font-size:20px;color:#2A2521;margin:0 0 8px;">ปูพื้นฐานลูกหมา</h3>
        <p style="font-size:14.5px;color:#7c7266;line-height:1.7;margin:0;">นั่ง · คอย · เรียกมา — เริ่มต้นให้ถูกตั้งแต่วันแรก</p>
      </div>
      <div style="position:relative;background:#fff;border-radius:20px;padding:26px 24px;border:1px solid rgba(140,120,80,.16);box-shadow:0 10px 24px -18px rgba(42,37,33,.6);transition:transform .18s,box-shadow .18s;" onmouseover="this.style.transform='translateY(-6px)';this.style.boxShadow='0 20px 36px -20px rgba(42,37,33,.55)'" onmouseout="this.style.transform='';this.style.boxShadow='0 10px 24px -18px rgba(42,37,33,.6)'">
        <div style="position:absolute;top:18px;right:18px;font-size:12px;font-weight:700;color:#DFA714;letter-spacing:.08em;">CARD 02</div>
        <div style="font-size:38px;margin-bottom:14px;">🏠</div>
        <h3 style="font-family:'Chonburi',serif;font-weight:400;font-size:20px;color:#2A2521;margin:0 0 8px;">สมาชิกในบ้านที่น่ารัก</h3>
        <p style="font-size:14.5px;color:#7c7266;line-height:1.7;margin:0;">เดินสายจูงไม่ดึง · เข้ากรง · กินข้าวเป็นเวลา</p>
      </div>
      <div style="position:relative;background:#2A2521;border-radius:20px;padding:26px 24px;border:1px solid #2A2521;box-shadow:0 14px 30px -18px rgba(42,37,33,.8);transition:transform .18s,box-shadow .18s;" onmouseover="this.style.transform='translateY(-6px)';this.style.boxShadow='0 24px 40px -20px rgba(42,37,33,.7)'" onmouseout="this.style.transform='';this.style.boxShadow='0 14px 30px -18px rgba(42,37,33,.8)'">
        <div style="position:absolute;top:16px;right:16px;background:#F4C13C;color:#20302F;font-size:11px;font-weight:700;padding:4px 10px;border-radius:999px;">ของถนัด</div>
        <div style="font-size:38px;margin-bottom:14px;">🎯</div>
        <h3 style="font-family:'Chonburi',serif;font-weight:400;font-size:20px;color:#F4C13C;margin:0 0 8px;">recall + เกม</h3>
        <p style="font-size:14.5px;color:rgba(251,248,241,.88);line-height:1.7;margin:0;">เรียกแล้ววิ่งมา — หัวใจของหมาสนุก</p>
      </div>
      <div style="position:relative;background:#fff;border-radius:20px;padding:26px 24px;border:1px solid rgba(140,120,80,.16);box-shadow:0 10px 24px -18px rgba(42,37,33,.6);transition:transform .18s,box-shadow .18s;" onmouseover="this.style.transform='translateY(-6px)';this.style.boxShadow='0 20px 36px -20px rgba(42,37,33,.55)'" onmouseout="this.style.transform='';this.style.boxShadow='0 10px 24px -18px rgba(42,37,33,.6)'">
        <div style="position:absolute;top:18px;right:18px;font-size:12px;font-weight:700;color:#DFA714;letter-spacing:.08em;">CARD 04</div>
        <div style="font-size:38px;margin-bottom:14px;">✨</div>
        <h3 style="font-family:'Chonburi',serif;font-weight:400;font-size:20px;color:#2A2521;margin:0 0 8px;">ทริก &amp; ความสนุก</h3>
        <p style="font-size:14.5px;color:#7c7266;line-height:1.7;margin:0;">ท่าเก๋ ๆ ที่กระชับความสัมพันธ์ไปด้วย</p>
      </div>
    </div>
    <p style="margin:32px auto 0;max-width:60ch;text-align:center;font-size:14.5px;color:#6b6157;background:#fff;border:1px dashed #8A6A18;border-radius:14px;padding:16px 22px;">ในเคสก้าวร้าว / กัด / ระแวง <strong style="color:#2A2521;">ขอคุยเป็นเคสบายเคสก่อนนะครับ</strong></p>
  </div>
</section>
