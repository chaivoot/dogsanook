---
import ImageSlot from './ImageSlot.astro';
// Susan Garrett = credit only, never claim instructor (CLAUDE.md §8).
// มอมแมม = inspiration, not a behaviour-fix ad (§9).
---
<section data-reveal style="background:#FBF8F1;padding:clamp(56px,8vw,110px) clamp(16px,4vw,48px);">
  <div style="max-width:1080px;margin:0 auto;display:flex;flex-wrap:wrap;gap:clamp(28px,5vw,56px);align-items:center;">
    <div style="flex:1 1 320px;min-width:280px;">
      <div style="aspect-ratio:4/3;border-radius:24px;overflow:hidden;box-shadow:0 24px 48px -24px rgba(42,37,33,.5);">
        <ImageSlot src="/uploads/1745999842474.jpg" alt="ครูวุฒิ กับมอมแมม สุนัขพันธุ์เชลตี้" placeholder="รูปครู + มอมแมม (เชลตี้)" />
      </div>
    </div>
    <div style="flex:1 1 380px;min-width:300px;">
      <h2 style="font-family:'Chonburi',serif;font-weight:400;font-size:clamp(27px,5vw,46px);line-height:1.2;margin:0 0 20px;color:#2A2521;">สวัสดีครับ เราคือหมาสนุก</h2>
      <p style="font-size:17px;line-height:1.85;color:#4a423a;margin:0 0 18px;">ผม <strong style="color:#8A6A18;">วุฒิ</strong> ครับ ฝึกด้วยแนวทางเล่นไปฝึกไป โดยเรียนจากคอร์สของ <strong>ซูซาน กาเร็ตต์</strong> — ครูฝึกและแชมป์ agility ระดับโลก</p>
      <div style="background:#F2E9D8;border-left:4px solid #8A6A18;border-radius:0 16px 16px 0;padding:20px 24px;">
        <p style="font-size:16px;line-height:1.85;color:#20302F;margin:0;">จุดเริ่มของหมาสนุกคือ <strong style="color:#2A2521;">มอมแมม</strong> (เชลตี้) คู่หูที่ทำให้ผมลงลึกกับวิธีนี้ จนเชื่อสุดใจว่า การให้หมาได้เลือกและสนุก สร้างความสัมพันธ์ที่แข็งแรงกว่าการบังคับเสมอ</p>
      </div>
      <a href="/mommam" style="display:inline-block;margin-top:18px;color:#8A6A18;font-weight:600;font-size:15px;text-decoration:none;">ดูโปรไฟล์การเรียนของมอมแมม →</a>
    </div>
  </div>
</section>
