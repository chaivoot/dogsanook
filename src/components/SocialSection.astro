---
import { site } from '../config/site';
const links = [
  { label: '🎵 TikTok @dogsanook', href: site.social.tiktok },
  { label: '▶️ YouTube @dogsanook', href: site.social.youtube },
  { label: '📸 Instagram @dogsanook', href: site.social.instagram },
  { label: '👍 Facebook หมาสนุก', href: site.social.facebook },
];
---
<section data-reveal style="background:#F2E9D8;padding:clamp(48px,7vw,90px) clamp(16px,4vw,48px);">
  <div style="max-width:900px;margin:0 auto;text-align:center;">
    <h2 style="font-family:'Chonburi',serif;font-weight:400;font-size:clamp(24px,4vw,40px);line-height:1.2;margin:0 0 8px;color:#2A2521;">ตามดูเราได้ที่</h2>
    <p style="font-size:15px;color:#6b6157;margin:0 0 32px;">ยังไม่พร้อมจ้าง? กดตามไว้ก่อนได้เลย</p>
    <div style="display:flex;flex-wrap:wrap;gap:12px;justify-content:center;">
      {links.map((l) => (
        <a href={l.href} target="_blank" rel="noopener me" style="display:inline-flex;align-items:center;gap:8px;background:#fff;color:#20302F;font-weight:600;font-size:15px;padding:12px 22px;border-radius:999px;text-decoration:none;border:1px solid rgba(140,120,80,.2);transition:transform .15s;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform=''">{l.label}</a>
      ))}
    </div>
  </div>
</section>
