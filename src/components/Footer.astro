---
import { site } from '../config/site';
const year = 2568; // พ.ศ. — matches the mockup
---
<footer style="background:#201C19;color:rgba(251,248,241,.7);padding:36px clamp(16px,4vw,48px);text-align:center;font-size:13.5px;">
  <p style="margin:0 0 6px;">ครูฝึกสุนัขถึงบ้าน กรุงเทพฯ · เล่นไปฝึกไป ไม่ดุ ไม่บังคับ</p>
  <p style="margin:0 0 6px;">ให้บริการโซนกรุงเทพกรีฑา · รามคำแหง · พระราม 9 · ลาดกระบัง · บางพลี และพื้นที่ใกล้เคียง</p>
  <p style="margin:0 0 6px;">
    ติดต่อ:
    <a href={site.lineUrl} target="_blank" rel="noopener" style="color:#F4C13C;">LINE {site.lineOaId}</a>
    ·
    <a href={`tel:${site.phoneTel}`} style="color:#F4C13C;">โทร {site.phone}</a>
  </p>
  {site.hours && <p style="margin:0 0 6px;">🕚 {site.hours}</p>}
  <nav aria-label="ลิงก์ภายในเว็บไซต์" style="margin:14px 0 6px;line-height:2;">
    <a href="/" style="color:#F4C13C;">หน้าแรก</a>
    ·
    <a href="/course" style="color:#F4C13C;">ฝึกสุนัข 10 เกม</a>
    ·
    <a href="/mommam" style="color:#F4C13C;">โปรไฟล์การเรียนมอมแมม</a>
    ·
    <a href="/blog" style="color:#F4C13C;">บทความฝึกสุนัข</a>
  </nav>
  <p style="margin:0 0 6px;">
    <a href="/terms" style="color:rgba(251,248,241,.7);">ข้อกำหนดและเงื่อนไข</a>
    ·
    <a href="/privacy" style="color:rgba(251,248,241,.7);">นโยบายความเป็นส่วนตัว</a>
  </p>
  <p style="margin:0;">© {year} dogsanook.com</p>
</footer>
