---
import { getCollection } from 'astro:content';
import ImageSlot from './ImageSlot.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
---
<section id="blog" data-reveal style="background:#FBF8F1;padding:clamp(56px,8vw,110px) clamp(16px,4vw,48px);">
  <div style="max-width:1120px;margin:0 auto;">
    <div style="display:flex;flex-wrap:wrap;gap:14px;align-items:flex-end;justify-content:space-between;margin-bottom:40px;">
      <div>
        <div style="font-weight:700;font-size:13px;letter-spacing:.08em;color:#DFA714;margin-bottom:8px;">ความรู้ฝึกหมา</div>
        <h2 style="font-family:'Chonburi',serif;font-weight:400;font-size:clamp(28px,5vw,50px);line-height:1.2;margin:0;color:#2A2521;">อ่านก่อนเริ่มฝึก</h2>
      </div>
      <a href="/blog" style="display:inline-flex;align-items:center;gap:6px;color:#8A6A18;font-weight:600;font-size:15px;text-decoration:none;">ดูบทความทั้งหมด →</a>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:22px;">
      {posts.map((post) => (
        <a href={`/blog/${post.id}`} style="text-decoration:none;color:inherit;display:flex;flex-direction:column;background:#fff;border:1px solid rgba(140,120,80,.16);border-radius:20px;overflow:hidden;box-shadow:0 10px 24px -18px rgba(42,37,33,.6);transition:transform .18s,box-shadow .18s;" onmouseover="this.style.transform='translateY(-6px)';this.style.boxShadow='0 20px 36px -20px rgba(42,37,33,.55)'" onmouseout="this.style.transform='';this.style.boxShadow='0 10px 24px -18px rgba(42,37,33,.6)'">
          <div style="aspect-ratio:16/10;">
            <ImageSlot src={post.data.heroImage} alt={post.data.heroAlt ?? post.data.title} placeholder="ภาพประกอบบทความ" />
          </div>
          <div style="padding:20px 22px;">
            <div style="font-size:12px;font-weight:700;color:#DFA714;letter-spacing:.05em;margin-bottom:8px;">{post.data.category}</div>
            <h3 style="font-family:'Sarabun',sans-serif;font-weight:700;font-size:18px;color:#2A2521;margin:0 0 8px;line-height:1.4;">{post.data.title}</h3>
            <p style="font-size:14px;color:#7c7266;line-height:1.65;margin:0;">{post.data.description}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
