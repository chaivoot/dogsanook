---
import { site } from '../config/site';
// Every "แอด LINE" CTA on the site opens the LINE OA (site.lineUrl) directly.
const hoursLine = site.hours ? ` · ${site.hours}` : '';
---
<section id="line" data-reveal style="background:linear-gradient(180deg,#2A2521 0%,#201C19 100%);color:#FBF8F1;padding:clamp(64px,9vw,120px) clamp(16px,4vw,48px);text-align:center;">
  <div style="max-width:720px;margin:0 auto;">
    <img src="/uploads/logo-gold-mark.png" alt="โลโก้ หมาสนุก" width="132" height="132" style="width:132px;height:132px;margin:0 auto 20px;display:block;" />
    <h2 style="font-family:'Chonburi',serif;font-weight:400;font-size:clamp(28px,5vw,50px);line-height:1.25;margin:0 0 22px;color:#FBF8F1;text-wrap:balance;">พร้อมให้น้องเริ่ม<span style="color:#F4C13C;">เล่นไปฝึกไป</span>หรือยัง?</h2>
    <div style="display:flex;flex-wrap:wrap;gap:14px;align-items:center;justify-content:center;">
      <a href={site.lineUrl} target="_blank" rel="noopener" class="btn-gold" style="font-size:18px;padding:17px 34px;" onmouseover="this.style.transform='translateY(2px)';this.style.boxShadow='0 4px 0 #DFA714'" onmouseout="this.style.transform='';this.style.boxShadow='0 6px 0 #DFA714'"><span style="font-size:20px;">💬</span> แอด LINE ปรึกษาฟรี</a>
      <a href={`tel:${site.phoneTel}`} style="display:inline-flex;align-items:center;gap:9px;background:transparent;color:#FBF8F1;font-weight:700;font-size:17px;padding:15px 28px;border-radius:999px;text-decoration:none;border:2px solid rgba(251,248,241,.55);transition:border-color .15s;" onmouseover="this.style.borderColor='#F4C13C'" onmouseout="this.style.borderColor='rgba(251,248,241,.55)'"><span style="font-size:18px;">📞</span> โทร {site.phone}</a>
    </div>
    <p style="font-size:14px;color:rgba(251,248,241,.7);margin:16px 0 0;">สะดวกโทรมากกว่า? โทรได้เลยในเวลาทำการ</p>
    <p style="font-size:15px;color:rgba(251,248,241,.8);margin:14px 0 0;">📍 รามคำแหง · กรุงเทพกรีฑา · พระราม 9 · ลาดกระบัง{hoursLine}</p>
  </div>
</section>
